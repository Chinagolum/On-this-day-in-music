# === CRITICAL SECRETS (NEVER COMMIT) ===
# Environment variables with ALL credentials
.env
.env.local
.env.*.local

# Terraform secrets
terraform.tfvars
*.auto.tfvars
*.tfstate
*.tfstate.*
*.tfstate.backup

# AWS credentials in config files
cloudwatch-datasource.json
telegram-contact.json
alert-*.json
dashboard.json

# Lambda responses (may contain DB data)
response.json

# === BUILD ARTIFACTS (Contain dependencies) ===
# Virtual environments
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# Python compiled
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]

# Lambda deployment packages
*.zip
build/
package/
dist/

# Terraform providers
.terraform/

# Test coverage
.coverage
.coverage.*
.pytest_cache/
htmlcov/

# === SYSTEM FILES ===
.DS_Store
.vscode/
.idea/
*.log

# Selenium logs
selenium_logs/

# === TEMPORARY FILES ===
*.tmp
*.bak
temp/
tmp/

# Terraform crash logs
crash.log

# === BLOAT PREVENTION ===
# Large data files
*.csv
*.json
*.xlsx
*.db
*.sqlite
*.sqlite3

# Except these specific files (override with !)
!terraform/*.json
!package.json
!tsconfig.json

# Screenshots/images (unless in docs/)
*.png
*.jpg
*.jpeg
*.gif
!docs/**/*.png
!docs/**/*.jpg

# Video files
*.mp4
*.mov
*.avi

# Archives
*.tar
*.tar.gz
*.rar
*.7z

# Node modules (if you ever add JS)
node_modules/